# Optional. Install-And-Run.ps1 can also read the token created by `huggingface-cli login`.
HF_TOKEN=

# Optional host output directory. Defaults to ./outputs when unset.
SCENEMA_OUTPUT_DIR=./outputs

# Optional for default INT8 mode. bf16 mode enables this automatically.
# Set to 1 to offload Scenema audio models before Gemma, Whisper, and SeedVC.
OFFLOAD_AUDIO_BEFORE_AUX=0
